RewriteEngine On

# HTTP -> HTTPS (contează și X-Forwarded-Proto — necesar în spatele proxy-ului
# Coolify, care termină TLS și trimite HTTP simplu către container; altfel
# %{HTTPS} rămâne mereu "off" și apare buclă infinită de redirect)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# URL curat: /servicii -> servicii.php (dacă fișierul .php există și nu e cerere directă de fișier/folder existent)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

ErrorDocument 404 /404.php

# Blochează accesul web direct la foldere interne
RewriteRule ^(includes|config|vendor)/ - [F,L]
